{
  "name": "font-inspector",
  "version": "0.1.0",
  "description": "Hover-based font inspector overlay for React apps — shows family, token, weight, style, size, and line-height of any element.",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
